<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Admin Dashboard - Home</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

        :root {
            --clr-bg-page:        #e8e4dd;
            --clr-bg-header:      #ffffff;
            --clr-bg-card:        #ffffff;

            --clr-teal-50:        #E1F5EE;
            --clr-teal-100:       #9FE1CB;
            --clr-teal-200:       #5DCAA5;
            --clr-teal-400:       #1D9E75;
            --clr-teal-600:       #0F6E56;
            --clr-teal-800:       #085041;

            --clr-purple-50:      #EEEDFE;
            --clr-purple-100:     #CECBF6;
            --clr-purple-200:     #AFA9EC;
            --clr-purple-400:     #7F77DD;
            --clr-purple-600:     #534AB7;
            --clr-purple-800:     #3C3489;

            --clr-gray-50:        #F1EFE8;
            --clr-gray-100:       #D3D1C7;
            --clr-gray-400:       #888780;
            --clr-gray-600:       #5F5E5A;
            --clr-gray-900:       #2C2C2A;

            --clr-text-primary:   #1a1a18;
            --clr-text-secondary: #5F5E5A;
            --clr-text-muted:     #888780;

            --clr-border-default: rgba(0,0,0,0.08);
            --clr-border-hover:   rgba(0,0,0,0.14);

            --radius-card:    24px;
            --radius-btn:     13px;
            --transition:     0.24s ease;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: var(--clr-bg-page);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--clr-text-primary);
        }

        /* ── Header ── */
        .dashboard-header {
            background: var(--clr-bg-header);
            border-bottom: 1px solid var(--clr-border-default);
            height: 66px;
            display: flex;
            align-items: center;
            padding: 0 2.5rem;
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .dashboard-header h1 {
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.01em;
            color: var(--clr-text-primary);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Animated teal brand mark */
        .dashboard-header h1::before {
            content: '';
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--clr-teal-400);
            flex-shrink: 0;
            animation: pulse-dot 2.8s ease-in-out infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { box-shadow: 0 0 0 0 rgba(29,158,117,0.45); }
            50%       { box-shadow: 0 0 0 6px rgba(29,158,117,0); }
        }

        /* ── Main ── */
        .dashboard-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1.5rem;
        }

        /* ── Card ── */
        .glass-card {
            background: var(--clr-bg-card);
            border-radius: var(--radius-card);
            border: 1px solid var(--clr-border-default);
            padding: 3rem 2.75rem 2.75rem;
            width: 100%;
            max-width: 440px;
            transition: border-color var(--transition);
        }

        .glass-card:hover {
            border-color: var(--clr-border-hover);
        }

        /* ── Card heading ── */
        .glass-card h2 {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--clr-text-muted);
            margin-bottom: 1.75rem;
            padding-bottom: 1.1rem;
            border-bottom: 1px solid var(--clr-border-default);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .glass-card h2::before {
            content: '';
            display: inline-block;
            width: 16px;
            height: 2px;
            border-radius: 99px;
            background: var(--clr-teal-400);
            flex-shrink: 0;
        }

        /* ── Nav menu ── */
        .nav-menu {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* ── Nav links — base ── */
        .nav-menu a {
            display: flex;
            align-items: center;
            justify-content: space-between;
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            padding: 14px 20px;
            border-radius: var(--radius-btn);
            border: 1px solid var(--clr-border-default);
            transition:
                background    var(--transition),
                color         var(--transition),
                border-color  var(--transition),
                transform     0.13s ease,
                box-shadow    var(--transition);
            position: relative;
            overflow: hidden;
        }

        /* Arrow indicator via ::after */
        .nav-menu a::after {
            content: '→';
            font-size: 14px;
            opacity: 0;
            transform: translateX(-6px);
            transition:
                opacity   var(--transition),
                transform var(--transition);
        }

        /* ── Add Course — teal ── */
        .nav-menu a:nth-child(1) {
            color: var(--clr-teal-800);
            background: var(--clr-teal-50);
            border-color: var(--clr-teal-100);
        }

        .nav-menu a:nth-child(1):hover {
            background: var(--clr-teal-100);
            border-color: var(--clr-teal-200);
            color: var(--clr-teal-800);
            box-shadow: 0 4px 18px rgba(29,158,117,0.14);
        }

        /* ── Search Course — purple ── */
        .nav-menu a:nth-child(2) {
            color: var(--clr-purple-800);
            background: var(--clr-purple-50);
            border-color: var(--clr-purple-100);
        }

        .nav-menu a:nth-child(2):hover {
            background: var(--clr-purple-100);
            border-color: var(--clr-purple-200);
            color: var(--clr-purple-800);
            box-shadow: 0 4px 18px rgba(127,119,221,0.16);
        }

        /* ── View All — warm gray, elevated ── */
        .nav-menu a:nth-child(3) {
            color: var(--clr-text-primary);
            background: var(--clr-gray-50);
            border-color: var(--clr-gray-100);
        }

        .nav-menu a:nth-child(3):hover {
            background: var(--clr-gray-100);
            border-color: rgba(0,0,0,0.18);
            color: var(--clr-gray-900);
            box-shadow: 0 4px 18px rgba(0,0,0,0.08);
        }

        /* Shared hover states */
        .nav-menu a:hover {
            transform: translateX(4px);
        }

        .nav-menu a:hover::after {
            opacity: 1;
            transform: translateX(0);
        }

        .nav-menu a:active {
            transform: translateX(2px) scale(0.985);
            box-shadow: none;
        }

        /* ── Footer label ── */
        .glass-card::after {
            content: 'Course Management System';
            display: block;
            margin-top: 2rem;
            font-size: 10.5px;
            font-weight: 500;
            letter-spacing: 0.08em;
            text-align: center;
            color: var(--clr-text-muted);
            text-transform: uppercase;
        }

        /* ── Responsive ── */
        @media (max-width: 480px) {
            .dashboard-header {
                padding: 0 1.25rem;
            }

            .glass-card {
                padding: 2.25rem 1.5rem 2rem;
                border-radius: 18px;
            }

            .nav-menu a {
                font-size: 13px;
                padding: 13px 16px;
            }
        }
    </style>
</head>
<body>

    <header class="dashboard-header">
        <h1>Course Management System</h1>
    </header>

    <main class="dashboard-main">
        <div class="glass-card">
            <h2>Select the Field</h2>

            <div class="nav-menu">
                <a href="/addCourse">Add Course</a>
                <a href="/searchCourse">Search Course</a>
                <a href="/ViewAllCourse">View All Courses</a>
            </div>
        </div>
    </main>

</body>
</html>