<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

        :root {
            --clr-bg-page:         #e8e4dd;
            --clr-bg-card:         #ffffff;
            --clr-bg-header:       #ffffff;
            --clr-bg-input:        #f6f4f0;
            --clr-bg-input-focus:  #ffffff;

            --clr-teal-50:         #E1F5EE;
            --clr-teal-100:        #9FE1CB;
            --clr-teal-400:        #1D9E75;
            --clr-teal-600:        #0F6E56;
            --clr-teal-800:        #085041;

            --clr-purple-50:       #EEEDFE;
            --clr-purple-100:      #CECBF6;
            --clr-purple-200:      #AFA9EC;
            --clr-purple-600:      #534AB7;
            --clr-purple-800:      #3C3489;

            --clr-amber-50:        #FAEEDA;
            --clr-amber-100:       #FAC775;
            --clr-amber-600:       #854F0B;
            --clr-amber-800:       #633806;

            --clr-gray-50:         #F1EFE8;
            --clr-gray-100:        #D3D1C7;
            --clr-gray-400:        #888780;
            --clr-gray-600:        #5F5E5A;
            --clr-gray-900:        #2C2C2A;

            --clr-text-primary:    #1a1a18;
            --clr-text-secondary:  #5F5E5A;
            --clr-text-muted:      #888780;

            --clr-border-default:  rgba(0,0,0,0.08);
            --clr-border-hover:    rgba(0,0,0,0.15);
            --clr-focus-ring:      rgba(29,158,117,0.18);

            --radius-card:   22px;
            --radius-input:  11px;
            --radius-btn:    11px;
            --transition:    0.22s ease;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: var(--clr-bg-page);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--clr-text-primary);
        }

        /* ── Page header bar ── */
        body > div:first-child {
            background: var(--clr-bg-header);
            border-bottom: 1px solid var(--clr-border-default);
            height: 64px;
            display: flex;
            align-items: center;
            padding: 0 2.5rem;
            position: sticky;
            top: 0;
            z-index: 20;
        }

        body > div:first-child h1 {
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: 0.13em;
            text-transform: uppercase;
            color: var(--clr-amber-600);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Amber edit-mode indicator dot */
        body > div:first-child h1::before {
            content: '';
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--clr-amber-100);
            border: 2px solid var(--clr-amber-600);
            flex-shrink: 0;
        }

        /* ── Main content wrapper ── */
        body > div:last-child {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1.5rem;
        }

        /* ── Form card ── */
        body > div:last-child form {
            background: var(--clr-bg-card);
            border-radius: var(--radius-card);
            border: 1px solid var(--clr-border-default);
            padding: 0 0 0;
            width: 100%;
            max-width: 480px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: border-color var(--transition);
        }

        body > div:last-child form:hover {
            border-color: var(--clr-border-hover);
        }

        /* Amber strip replacing the missing inner heading */
        body > div:last-child form::before {
            content: 'Editing Course Record';
            display: block;
            padding: 1rem 2rem;
            background: var(--clr-amber-50);
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 0.13em;
            text-transform: uppercase;
            color: var(--clr-amber-800);
            border-bottom: 1px solid var(--clr-amber-100);
        }

        /* ── Input wrapper rows ── */
        body > div:last-child form input {
            display: block;
            width: 100%;
            padding: 12px 20px;
            font-family: inherit;
            font-size: 14px;
            font-weight: 400;
            color: var(--clr-text-primary);
            background: var(--clr-bg-input);
            border: none;
            border-bottom: 1px solid var(--clr-border-default);
            outline: none;
            transition:
                background  var(--transition),
                color       var(--transition),
                box-shadow  var(--transition),
                border-color var(--transition);
        }

        body > div:last-child form input:hover {
            background: var(--clr-gray-50);
        }

        body > div:last-child form input:focus {
            background: var(--clr-bg-input-focus);
            border-bottom-color: var(--clr-teal-400);
            box-shadow: inset 0 -3px 0 0 var(--clr-teal-400);
            color: var(--clr-text-primary);
            z-index: 1;
            position: relative;
        }

        body > div:last-child form input:last-of-type {
            border-bottom: 1px solid var(--clr-border-default);
        }

        /* Placeholder contrast */
        body > div:last-child form input::placeholder {
            color: var(--clr-text-muted);
            font-size: 13px;
        }

        /* Remove number spinners */
        body > div:last-child form input[type="number"]::-webkit-inner-spin-button,
        body > div:last-child form input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
        }
        
        /* ── Submit button ── */
        body > div:last-child form button[type="submit"] {
            display: block;
            width: calc(100% - 3rem);
            margin: 1.5rem auto;
            padding: 13px 24px;
            font-family: inherit;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #ffffff;
            background: var(--clr-amber-600);
            border: none;
            border-radius: var(--radius-btn);
            cursor: pointer;
            transition:
                background  var(--transition),
                box-shadow  var(--transition),
                transform   0.12s ease;
        }

        body > div:last-child form button[type="submit"]:hover {
            background: var(--clr-amber-800);
            box-shadow: 0 4px 20px rgba(133,79,11,0.28);
        }

        body > div:last-child form button[type="submit"]:active {
            transform: scale(0.975);
            box-shadow: none;
            background: #4a2802;
        }

        body > div:last-child form button[type="submit"]:focus-visible {
            outline: 3px solid rgba(133,79,11,0.2);
            outline-offset: 2px;
        }

        /* ── Responsive ── */
        @media (max-width: 520px) {
            body > div:first-child {
                padding: 0 1.25rem;
            }

            body > div:last-child form input {
                padding: 11px 1.25rem;
                font-size: 13.5px;
            }

            body > div:last-child form button[type="submit"] {
                width: calc(100% - 2rem);
                margin: 1.25rem auto;
            }
        }
    </style>
</head>
<body>

    <div>
        <h1>Update Course Details</h1>
    </div>

    <div>
        <form action="/changeDetails/<%=updatedata._id%>" method="POST">
            <input type="text"   name="CourseName"     value="<%=updatedata.CourseName%>">
            <input type="number" name="CourseDuration"  value="<%=updatedata.CourseDuration%>">
            <input type="text"   name="TrainerName"     value="<%=updatedata. TrainerName%>">
            <input type="number" name="FessOfCourse"    value="<%=updatedata.FessOfCourse%>">
            <input type="text"   name="ModeofCourse"    value="<%=updatedata.ModeofCourse%>">
            <button type="submit">UPDATE COURSE</button>
        </form>
    </div>

</body>
</html>